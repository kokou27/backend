# ============================================================
# VARIABLES D'ENVIRONNEMENT — à configurer via `wrangler secret put NOM`
# (voir wrangler.toml). Copie ce fichier, renomme-le .env.local pour
# tester en local avec `wrangler dev`.
# NE JAMAIS committer le vrai .env avec les vraies clés !
# ============================================================


# ── SUPABASE ────────────────────────────────────────────────
# Disponible dans : supabase.com → ton projet → Settings → API
SUPABASE_URL=https://XXXXXXXX.supabase.co
SUPABASE_SECRET_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...


# ── GEMINI API ──────────────────────────────────────────────
# Disponible dans : aistudio.google.com → Get API key
# Clé PAYANTE pour la production (tes clients)
GEMINI_API_KEY=AIzaSy...

# Modèles utilisés (optionnel — gemini-2.5-flash par défaut)
# Changer ici si tu veux tester un modèle différent sans toucher au code
GEMINI_MODEL_ZONE=gemini-2.5-flash
GEMINI_MODEL_OCR=gemini-2.5-flash
GEMINI_MODEL_DEFAULT=gemini-2.5-flash


# ── SYSTÈME DE CRÉDITS (NOUVEAU — basé sur les tokens réels) ─
#
# COMMENT ÇA MARCHE :
#   1. Chaque appel Gemini retourne le nombre de tokens utilisés
#   2. On calcule le coût réel : (input_tokens × input_rate + output_tokens × output_rate)
#   3. On multiplie par CREDIT_MARKUP_FACTOR (ta marge)
#   4. On divise par USD_PER_CREDIT pour obtenir le nombre de crédits à débiter
#   5. On déduira ce montant du solde de l'utilisateur
#
# EXEMPLE avec les valeurs par défaut ci-dessous :
#   Zone translate typique :
#     - 5 000 tokens input  → 5000 × 0.15 / 1 000 000 = $0.00075
#     - 1 000 tokens output → 1000 × 0.60 / 1 000 000 = $0.00060
#     - Coût Gemini total   = $0.00135
#     - × markup 2.5        = $0.003375 (ta recette)
#     - ÷ 0.005 $/crédit    = 0.675 → arrondi à 1 crédit
#     - L'utilisateur paie 1 crédit = $0.005 (au tarif Pack Découverte)
#     - TON BÉNÉFICE : $0.005 - $0.00135 = $0.00365 par zone translate ✅
#
#   Page translate complète (10 segments) :
#     - ~50 000 tokens input + ~15 000 output = coût Gemini ~$0.017
#     - × 2.5 = $0.042
#     - ÷ 0.005 = 8.4 → arrondi à 9 crédits
#     - L'utilisateur paie 9 crédits = $0.045
#     - TON BÉNÉFICE : $0.045 - $0.017 = $0.028 par page traduite ✅

# Prix réels Gemini 2.5 Flash (thinkingBudget: 0 activé = thinking désactivé)
GEMINI_INPUT_USD_PER_1M_TOKENS=0.15
GEMINI_OUTPUT_USD_PER_1M_TOKENS=0.60

# Ta marge appliquée sur le coût Gemini
# 2.5 = tu factures 2.5× le coût Gemini → marge brute de 150%
# Tu peux augmenter (ex: 3.0) si tu veux plus de marge
# Tu peux baisser (ex: 2.0) si tu veux être plus compétitif
CREDIT_MARKUP_FACTOR=2.5

# Valeur d'1 crédit en dollars
# 0.005 = 1 crédit vaut $0.005 (Pack Découverte : 1000 crédits = $4.99 ≈ $0.00499/crédit)
# Si tu changes les prix de tes packs Lemon Squeezy, mets à jour cette valeur
USD_PER_CREDIT=0.005


# ── RENTABILITÉ PAR PACK ─────────────────────────────────────
# Pack Découverte  : 1 000 crédits × $0.005 = $5.00 recette
#                   Coût Gemini moyen ~$2.00 → MARGE ~$3.00 (60%)
# Pack Standard   : 3 000 crédits × $0.005 = $15.00 recette → MARGE ~$9.00
# Pack Pro        : 10 000 crédits × $0.005 = $50.00 recette → MARGE ~$30.00
# (Lemon Squeezy prend ~5% de commission en sus)


# ── TRIAL GRATUIT ────────────────────────────────────────────
# Nombre de traductions IA gratuites par jour pour les non-Pro
# 2 = 2 traductions/jour (valeur actuelle)
DAILY_TRIAL_LIMIT=2


# ── BOUTON D'ACHAT ──────────────────────────────────────────
# true  = le bouton "Recharger" est visible dans la sidebar
# false = le bouton est caché (mode test / pas encore en prod)
BUY_BUTTON_ENABLED=true


# ── LEMON SQUEEZY ───────────────────────────────────────────
# Disponible dans : app.lemonsqueezy.com → Settings → Webhooks
LEMON_SQUEEZY_WEBHOOK_SECRET=whsec_...


# ── RESEND (emails) ─────────────────────────────────────────
# Disponible dans : resend.com → API Keys
RESEND_API_KEY=re_...


# ── DEV MODE (optionnel) ─────────────────────────────────────
# Permet de tester en mode Pro sans payer, sur ton extension perso
# DEV_PRO_ENABLED=true
# DEV_PRO_EXTENSION_IDS=ton_extension_id_ici
# DEV_PRO_EMAIL=kokoukoumassi27@gmail.com


# ── NODE ────────────────────────────────────────────────────
NODE_NO_WARNINGS=1
